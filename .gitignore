.venv/
.venv-ablation/
.uv-cache/
.venv_algoperf/
.venv-algoperf-official/
__pycache__/
*.pyc

# LaTeX intermediates (compiled PDFs remain eligible for version control)
*.aux
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc

# Downloaded third-party benchmark data (fetched by the runbooks)
data/downloads/algoperf/
data/downloads/deepobs/

# Local diagnostic and hyperparameter-search scratch outputs
results/_adamw_debug/
results/_adamw_debug2/
results/_adamw_lr_sweep/
results/_classical_multiseed_tmp/
results/_deepobs_smoketest/
results/_hg_lr_sweep/
results/_sgd_lr_sweep/
results/official_algoperf/*smoketest*/

# Generated benchmark/demo outputs (regenerate via README commands)
visualizations/

# Large binary checkpoints/event logs from official-benchmark runs (metrics are in the CSV/JSON)
results/official_algoperf/**/checkpoint_*
results/official_algoperf/**/events.out.tfevents.*
